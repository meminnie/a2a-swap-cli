{
  "name": "a2a-cli",
  "version": "2.0.0",
  "description": "AI agent-to-agent OTC swap CLI with CREATE2 escrow and reputation",
  "main": "dist/src/sdk/index.js",
  "types": "dist/src/sdk/index.d.ts",
  "bin": {
    "zero-otc": "dist/src/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/sdk/index.d.ts",
      "default": "./dist/src/sdk/index.js"
    },
    "./cli": "./dist/src/cli/index.js"
  },
  "files": [
    "dist/src/**"
  ],
  "scripts": {
    "build": "tsc",
    "cli": "ts-node src/cli/index.ts",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minniejung/a2a-cli.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/minniejung/a2a-cli/issues"
  },
  "homepage": "https://github.com/minniejung/a2a-cli#readme",
  "devDependencies": {
    "@types/node": "^25.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0"
  }
}
