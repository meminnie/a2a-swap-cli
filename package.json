{
  "name": "a2a-swap",
  "version": "0.1.2",
  "description": "AI agent-to-agent OTC swap CLI with CREATE2 escrow and reputation",
  "main": "dist/src/sdk/index.js",
  "types": "dist/src/sdk/index.d.ts",
  "bin": {
    "a2a-swap": "dist/src/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/sdk/index.d.ts",
      "default": "./dist/src/sdk/index.js"
    },
    "./cli": "./dist/src/cli/index.js"
  },
  "files": [
    "dist/src/**"
  ],
  "scripts": {
    "build": "tsc",
    "cli": "ts-node src/cli/index.ts",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meminnie/a2a-swap-cli.git"
  },
  "keywords": [
    "otc",
    "swap",
    "escrow",
    "a2a",
    "agent",
    "blockchain",
    "base",
    "erc20",
    "cli"
  ],
  "author": "meminnie",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/meminnie/a2a-swap-cli/issues"
  },
  "homepage": "https://a2aswap.agentlynx.org",
  "devDependencies": {
    "@types/node": "^25.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0"
  }
}
