{
  "name": "a2a-cli",
  "version": "1.0.0",
  "description": "AI agent-to-agent OTC swap CLI with ERC-8004 trust gating",
  "main": "dist/src/sdk/index.js",
  "types": "dist/src/sdk/index.d.ts",
  "bin": {
    "zero-otc": "dist/src/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/sdk/index.d.ts",
      "default": "./dist/src/sdk/index.js"
    },
    "./cli": "./dist/src/cli/index.js",
    "./eliza": "./dist/src/integrations/eliza/index.js",
    "./virtuals": "./dist/src/integrations/virtuals/index.js"
  },
  "scripts": {
    "build": "hardhat compile && tsc",
    "cli": "ts-node src/cli/index.ts",
    "test": "hardhat test",
    "compile": "hardhat compile",
    "clean": "hardhat clean && rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minniejung/a2a-cli.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/minniejung/a2a-cli/issues"
  },
  "homepage": "https://github.com/minniejung/a2a-cli#readme",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@types/node": "^25.4.0",
    "hardhat": "^2.28.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@elizaos/core": ">=0.1.0",
    "@virtuals-protocol/game": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@elizaos/core": { "optional": true },
    "@virtuals-protocol/game": { "optional": true }
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "@supabase/supabase-js": "^2.99.1",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0"
  }
}
