# Server loads .env from the repo root (../../.env relative to server/src/)
# Copy this to the root .env and fill in values.

# Required
OPERATOR_PRIVATE_KEY=0x...          # Operator EOA (deploys + settles escrows)
FACTORY_ADDRESS=0x...               # Deployed EscrowFactory contract address
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...    # service_role key (write access)

# Optional
RPC_URL=https://sepolia.base.org
PORT=3000
HOST=0.0.0.0
CHAIN=base-sepolia
FEE_BPS=10                          # 0.1% (max 100 = 1%)
DEPOSIT_DEADLINE_SECONDS=300        # 5 minutes for buyer deposit
