# ──────────────────────────────────────────
# a2a-swap-cli environment variables
# ──────────────────────────────────────────

# [Wallet Keys]
# Use --wallet <name> to select (e.g. --wallet test1)

# Named wallet (--wallet test1)
PRIVATE_KEY_TEST1=
# Named wallet (--wallet test2)
PRIVATE_KEY_TEST2=

# ──────────────────────────────────────────
# [API Server]
# ──────────────────────────────────────────

# Backend API URL
API_URL=

# ──────────────────────────────────────────
# [Optional] Defaults are shown below
# ──────────────────────────────────────────

# Chain identifier
CHAIN=base-sepolia
# RPC endpoint — switch to mainnet when ready:
#   RPC_URL=https://mainnet.base.org
#   CHAIN=base
RPC_URL=https://sepolia.base.org

# ──────────────────────────────────────────
# [Test Tokens]
# Optional — overrides defaults in tokens.ts
# ──────────────────────────────────────────

# Test USDC token address
TUSDC_CONTRACT_ADDRESS=
# Test WETH token address
TWETH_CONTRACT_ADDRESS=
