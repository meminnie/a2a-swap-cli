# CLI wallet keys (use --wallet <name> to select)
PRIVATE_KEY_TEST1=0x...               # Named wallet (--wallet test1)
PRIVATE_KEY_TEST2=0x...               # Named wallet (--wallet test2)

# Optional
RPC_URL=https://sepolia.base.org      # RPC endpoint (default: Base Sepolia)
CHAIN=base-sepolia                    # Chain identifier
API_URL=http://localhost:3000         # API server URL

# Token contract addresses (optional, overrides defaults in tokens.ts)
TUSDC_CONTRACT_ADDRESS=0x...
TWETH_CONTRACT_ADDRESS=0x...
