# ──────────────────────────────────────────
# a2a-swap environment variables
# ──────────────────────────────────────────

# [Required]

# Wallet private key (use --wallet <name> to select)
PRIVATE_KEY_MYKEY=

# API server URL
API_URL=https://a2a-swap-server-production.up.railway.app

# ──────────────────────────────────────────
# [Optional] All below have sensible defaults
# ──────────────────────────────────────────

# Chain: "base-sepolia" (default) or "base"
# CHAIN=base-sepolia

# RPC endpoint (defaults per chain)
# RPC_URL=https://sepolia.base.org
